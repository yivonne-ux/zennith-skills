#!/usr/bin/env bash
# executor.sh - Continuous Mission Execution Daemon
# 
# Automatically executes incomplete missions from MISSIONS.md
# Runs every 2 minutes via cron

set -e
# --- OpenClaw cron-safe keys + PATH ---
KEYFILE="$HOME/.openclaw/.env.keys"
if [ -f "$KEYFILE" ]; then
  set -a
  # shellcheck disable=SC1090
  source "$KEYFILE"
  set +a
fi

# Cron has tiny PATH; ensure tools exist
export PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$PATH"
# --- end cron-safe block ---

export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_DIR="${HOME}/.openclaw/workspace"
MISSIONS_FILE="${WORKSPACE_DIR}/MISSIONS.md"
ROOMS_DIR="${WORKSPACE_DIR}/rooms"
LOG_FILE="${HOME}/.openclaw/logs/executor.log"
STATE_FILE="${HOME}/.openclaw/logs/executor-state.json"

# Agent domain mapping (using regular variables for portability)
get_agent_for_domain() {
  case "$1" in
    research|scraping) echo "artemis" ;;
    content|creative) echo "apollo" ;;
    pricing|channel) echo "hermes" ;;
    social) echo "iris" ;;
    analytics) echo "athena" ;;
    code|build) echo "taoz" ;;
    orchestration) echo "main" ;;
    *) echo "" ;;
  esac
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log() {
  echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

log_success() {
  echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

log_warn() {
  echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

log_error() {
  echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

# Ensure directories exist
mkdir -p "$(dirname "$LOG_FILE")"
mkdir -p "$ROOMS_DIR"

# Load state
load_state() {
  if [[ -f "$STATE_FILE" ]]; then
    cat "$STATE_FILE"
  else
    echo '{"executions": [], "lastRun": null}'
  fi
}

# Save state
save_state() {
  echo "$1" > "$STATE_FILE"
}

# Parse MISSIONS.md and find incomplete missions
parse_missions() {
  if [[ ! -f "$MISSIONS_FILE" ]]; then
    log_warn "Missions file not found: $MISSIONS_FILE"
    return
  fi
  
  local in_mission=false
  local mission_id=""
  local mission_title=""
  local mission_status=""
  local mission_owner=""
  local mission_priority=""
  local mission_blockers=""
  
  while IFS= read -r line; do
    # Stop parsing at section boundaries (completed missions, auto-execution, format docs)
    if [[ "$line" =~ ^##[[:space:]](Completed|Auto-Execution|Mission\ Format) ]]; then
      break
    fi

    # Detect mission header
    if [[ "$line" =~ ^###[[:space:]](M[0-9]+):[[:space:]](.+)$ ]]; then
      # Save BASH_REMATCH before inner regex overwrites it
      local new_id="${BASH_REMATCH[1]}"
      local new_title="${BASH_REMATCH[2]}"

      # Output previous mission if complete
      if [[ "$in_mission" == true && "$mission_status" =~ (IN_PROGRESS|ACTIVE|PLANNED|BLOCKED) ]]; then
        echo "${mission_id}|${mission_title}|${mission_status}|${mission_owner}|${mission_priority}|${mission_blockers}"
      fi

      # Start new mission
      in_mission=true
      mission_id="$new_id"
      mission_title="$new_title"
      mission_status=""
      mission_owner=""
      mission_priority=""
      mission_blockers=""
    fi
    
    # Parse mission fields
    if [[ "$line" =~ ^-[[:space:]]*\*\*Status:\*\*[[:space:]]*(.+)$ ]]; then
      mission_status="${BASH_REMATCH[1]}"
    fi
    if [[ "$line" =~ ^-[[:space:]]*\*\*Owner:\*\*[[:space:]]*(.+)$ ]]; then
      mission_owner="${BASH_REMATCH[1]}"
    fi
    if [[ "$line" =~ ^-[[:space:]]*\*\*Priority:\*\*[[:space:]]*(.+)$ ]]; then
      mission_priority="${BASH_REMATCH[1]}"
    fi
    if [[ "$line" =~ ^-[[:space:]]*\*\*Blockers:\*\*[[:space:]]*(.+)$ ]]; then
      mission_blockers="${BASH_REMATCH[1]}"
    fi
  done < "$MISSIONS_FILE"
  
  # Output last mission
  if [[ "$in_mission" == true && "$mission_status" =~ (IN_PROGRESS|ACTIVE|PLANNED|BLOCKED) ]]; then
    echo "${mission_id}|${mission_title}|${mission_status}|${mission_owner}|${mission_priority}|${mission_blockers}"
  fi
}

# Determine agent from mission details
determine_agent() {
  local title="$1"
  local owner="$2"
  # Extract primary owner (before any + or ,) for multi-owner missions
  local primary_owner=$(echo "$owner" | sed 's/[+,].*//' | tr '[:upper:]' '[:lower:]')
  local lower_title=$(echo "$title" | tr '[:upper:]' '[:lower:]')

  # Check primary owner first (case-insensitive)
  [[ "$primary_owner" == *"taoz"* ]] && { echo "taoz"; return; }
  [[ "$primary_owner" == *"athena"* ]] && { echo "athena"; return; }
  [[ "$primary_owner" == *"artemis"* ]] && { echo "artemis"; return; }
  [[ "$primary_owner" == *"apollo"* ]] && { echo "apollo"; return; }
  [[ "$primary_owner" == *"hermes"* ]] && { echo "hermes"; return; }
  [[ "$primary_owner" == *"iris"* ]] && { echo "iris"; return; }

  # Check title keywords
  [[ "$lower_title" == *"research"* || "$lower_title" == *"intelligence"* || "$lower_title" == *"scout"* ]] && { echo "artemis"; return; }
  [[ "$lower_title" == *"content"* || "$lower_title" == *"creative"* || "$lower_title" == *"template"* ]] && { echo "apollo"; return; }
  [[ "$lower_title" == *"pricing"* || "$lower_title" == *"channel"* ]] && { echo "hermes"; return; }
  [[ "$lower_title" == *"social"* ]] && { echo "iris"; return; }
  [[ "$lower_title" == *"analytics"* || "$lower_title" == *"reporting"* || "$lower_title" == *"report"* ]] && { echo "athena"; return; }
  [[ "$lower_title" == *"code"* || "$lower_title" == *"build"* || "$lower_title" == *"stability"* ]] && { echo "taoz"; return; }

  # Default to main for orchestration
  echo "main"
}

# Execute a mission
execute_mission() {
  local mission_id="$1"
  local mission_title="$2"
  local mission_status="$3"
  local mission_owner="$4"
  local mission_priority="$5"
  local mission_blockers="$6"
  
  log "Processing mission: $mission_id - $mission_title"

  # Check cooldown — don't re-delegate same mission within 2 hours
  local cooldown_file="${HOME}/.openclaw/logs/executor-cooldown-${mission_id}"
  if [[ -f "$cooldown_file" ]]; then
    local last_exec=$(cat "$cooldown_file" 2>/dev/null || echo "0")
    local now=$(date +%s)
    local elapsed=$(( now - last_exec ))
    if [[ $elapsed -lt 7200 ]]; then
      log "Cooldown: $mission_id was delegated $(( elapsed / 60 ))m ago (need 120m). Skipping."
      return 1
    fi
  fi

  # Check for blockers
  if [[ -n "$mission_blockers" && "$mission_blockers" != "None" && "$mission_blockers" != "*" ]]; then
    log_warn "Mission $mission_id has blockers: $mission_blockers"
    log_to_room "execution" "$mission_id" "blocked" "Has blockers: $mission_blockers"
    return 1
  fi
  
  # Determine agent
  local agent=$(determine_agent "$mission_title" "$mission_owner")
  log "Delegating to agent: $agent"
  
  # Log to execution room (single-line JSON)
  printf '{"ts":%s000,"mission_id":"%s","agent":"%s","status":"delegated","priority":"%s"}\n' \
    "$(date +%s)" "$mission_id" "$agent" "$mission_priority" >> "${ROOMS_DIR}/execution.jsonl"
  
  # Determine target room based on agent
  local target_room="build"
  case "$agent" in
    apollo) target_room="creative" ;;
    iris) target_room="social" ;;
    athena) target_room="exec" ;;
    hermes) target_room="exec" ;;
    taoz) target_room="build" ;;
    *) target_room="build" ;;
  esac

  # Skip main agent (orchestrator doesn't self-delegate)
  if [[ "$agent" == "main" ]]; then
    log "Mission $mission_id is for Zenni (orchestration) — skipping auto-delegation"
    return 0
  fi

  # Taoz tasks → use Claude Code CLI
  if [[ "$agent" == "taoz" ]]; then
    log "Routing $mission_id to Taoz (Claude Code)"
    delegate_to_taoz "$mission_id" "$mission_title" "$target_room"
    return $?
  fi

  # Delegate to real agent via dispatch
  delegate_to_agent "$agent" "$mission_id" "$mission_title" "$target_room"

  # Record cooldown
  date +%s > "${HOME}/.openclaw/logs/executor-cooldown-${mission_id}"
  
  return 0
}

# Delegate to Taoz — uses Claude Code CLI directly via terminal
delegate_to_taoz() {
  local mission_id="$1"
  local mission_title="$2"
  local room="${3:-build}"

  log "Delegating $mission_id to Taoz (Claude Code)"

  # Claude Code CLI — runs as separate process (not nested)
  local claude_bin="/usr/local/bin/claude"
  if [[ ! -x "$claude_bin" ]]; then
    log_error "Claude Code CLI not found at $claude_bin"
    delegate_to_agent "artemis" "$mission_id" "$mission_title" "$room"
    return $?
  fi

  # Unset CLAUDECODE to avoid nested session detection
  local brief="You are Taoz, the builder agent for GAIA CORP-OS. Execute mission $mission_id: $mission_title. Work in ~/.openclaw/workspace. When done, write your results to ~/.openclaw/workspace/rooms/${room}.jsonl as a single-line JSON entry."

  # Run with 5 min timeout, capture output
  local output
  output=$(env -u CLAUDECODE "$claude_bin" -p "$brief" --max-turns 10 2>&1) || true

  if [[ -n "$output" ]]; then
    # Post result to room
    local escaped_output=$(echo "$output" | tail -20 | python3 -c "import sys,json; print(json.dumps(sys.stdin.read().strip()))" 2>/dev/null || echo '"Taoz completed task"')
    printf '{"ts":%s000,"agent":"taoz","room":"%s","type":"mission-result","msg":%s}\n' \
      "$(date +%s)" "$room" "$escaped_output" >> "${ROOMS_DIR}/${room}.jsonl"
    log_success "Taoz completed $mission_id via Claude Code"
  else
    log_warn "Taoz returned empty output for $mission_id, falling back to artemis"
    delegate_to_agent "artemis" "$mission_id" "$mission_title" "$room"
  fi
}

# Get recent room context for an agent
get_room_context() {
  local room="$1"
  local room_file="${ROOMS_DIR}/${room}.jsonl"
  if [[ -f "$room_file" ]]; then
    tail -3 "$room_file" 2>/dev/null | while IFS= read -r line; do
      local agent_name=$(echo "$line" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('agent','?'))" 2>/dev/null || echo "?")
      local msg=$(echo "$line" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('msg','')[:120])" 2>/dev/null || echo "")
      if [[ -n "$msg" ]]; then
        echo "  - ${agent_name}: ${msg}"
      fi
    done
  fi
}

# Delegate to any agent via dispatch.sh
delegate_to_agent() {
  local agent="$1"
  local mission_id="$2"
  local mission_title="$3"
  local room="${4:-build}"

  local dispatch="${HOME}/.openclaw/skills/mission-control/scripts/dispatch.sh"

  log "Delegating $mission_id to $agent"

  # Build room context so agent knows what's happening
  local context=""
  local room_context=$(get_room_context "$room" 2>/dev/null)
  if [[ -n "$room_context" ]]; then
    context=" Recent activity in ${room} room:\n${room_context}"
  fi

  local brief="Execute mission $mission_id: $mission_title. IMPORTANT: Before starting, read your SOUL.md Room Protocol — check relevant rooms for context from other agents. Post your results to the ${room} room when done.${context}"

  if [[ -f "$dispatch" ]]; then
    bash "$dispatch" executor "$agent" request \
      "$brief" \
      "$room" 2>&1 | tee -a "$LOG_FILE"
    log_success "Delegated $mission_id to $agent via dispatch"
  else
    log_error "dispatch.sh not found at $dispatch"
    return 1
  fi
}


# Log to room (single-line JSON for JSONL compatibility)
log_to_room() {
  local room="$1"
  local mission_id="$2"
  local status="$3"
  local msg="$4"

  printf '{"ts":%s000,"mission_id":"%s","status":"%s","msg":"%s"}\n' \
    "$(date +%s)" "$mission_id" "$status" "$msg" >> "${ROOMS_DIR}/${room}.jsonl"
}

# Main execution
main() {
  log "=== Mission Executor Started ==="
  
  local state=$(load_state)
  local exec_count=0
  
  # Parse and execute missions
  while IFS='|' read -r mission_id mission_title mission_status mission_owner mission_priority mission_blockers; do
    [[ -z "$mission_id" ]] && continue
    
    log "Found mission: $mission_id ($mission_priority)"
    
    if execute_mission "$mission_id" "$mission_title" "$mission_status" "$mission_owner" "$mission_priority" "$mission_blockers"; then
      ((exec_count++))
    fi
    
    # Prevent overwhelming the system
    if [[ $exec_count -ge 3 ]]; then
      log_warn "Reached execution limit (3), pausing"
      break
    fi
    
    sleep 2
  done < <(parse_missions)
  
  # Update state
  state=$(echo "$state" | jq --arg date "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson count "$exec_count" \
    '.lastRun = $date | .executions += [{"time": $date, "count": $count}] | .executions |= .[-10:]')
  save_state "$state"
  
  log_success "=== Executor Complete: $exec_count missions processed ==="
}

# Run main
main "$@"
