# .ralphrc - Ralph project configuration
# Project: The Jade Oracle — AI Psychic Reading Product
# Documentation: https://github.com/frankbria/ralph-claude-code

# Project identification
PROJECT_NAME="jade-oracle"
PROJECT_TYPE="nodejs"

# Claude Code CLI command
CLAUDE_CODE_CMD="claude"

# Loop settings
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=15
CLAUDE_OUTPUT_FORMAT="json"

# Tool permissions — includes VPS deploy tools
ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(node *),Bash(python3 *),Bash(curl *),Bash(fly *),Bash(bash *),Bash(chmod *),Bash(cat *),Bash(wc *),Bash(head *),Bash(tail *),Bash(grep *),Bash(ls *),Bash(mkdir *),Bash(sleep *)"

# Session management
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Task sources
TASK_SOURCES="local"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70

# Auto-update Claude CLI at startup
CLAUDE_AUTO_UPDATE=false
