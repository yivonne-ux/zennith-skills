      "total_duration_range": [38, 50],
      "intent": ["awareness", "conversion"],
      "gaia_pipeline": "video-forge.sh produce --type ugc",
      "sequence": [
        {"position": 1, "aida_phase": "attention", "preferred_codes": ["A5", "A3"], "duration_range": [3, 5], "description": "Hook — relatable scenario or reaction", "gen_type": "kol_video"},
        {"position": 2, "aida_phase": "interest", "preferred_codes": ["I1", "I3"], "duration_range": [5, 8], "description": "Behind the scenes or premium materials", "gen_type": "broll_video"},
        {"position": 3, "aida_phase": "interest", "preferred_codes": ["I2", "I4"], "duration_range": [5, 7], "description": "Process or production method", "gen_type": "broll_video"},
        {"position": 4, "aida_phase": "desire", "preferred_codes": ["D1"], "duration_range": [8, 12], "description": "Person using/enjoying product", "gen_type": "kol_video"},
        {"position": 5, "aida_phase": "desire", "preferred_codes": ["D1", "D2"], "duration_range": [5, 8], "description": "Additional usage or receive scene", "gen_type": "kol_video"},
        {"position": 6, "aida_phase": "action", "preferred_codes": ["Act6"], "duration_range": [3, 5], "description": "CTA end card", "gen_type": "text_card"}
      ]
    },
