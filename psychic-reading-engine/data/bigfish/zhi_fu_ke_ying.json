{
  "天蓬": {
    "子": "主阴人暗害，水上生灾。",
    "丑": "主田土之争，阴私暗昧。",
    "寅": "主盗贼侵犯，夜间提防。",
    "卯": "主有口舌是非，暗中破耗。",
    "辰": "主水患，阴人作祟。",
    "巳": "主官非讼狱，防火灾。",
    "午": "主血光之灾，南方不利。",
    "未": "主田宅不安，阴人反复。",
    "申": "主行路遇盗，出行不利。",
    "酉": "主阴私事败露，口舌争端。",
    "戌": "主阴谋败露，牢狱之灾。",
    "亥": "主暗中有贵人助，宜静守。"
  },
  "天芮": {
    "子": "主疾病缠身，阴人有灾。",
    "丑": "主田宅有损，阴暗之事。",
    "寅": "主盗贼、疾病相侵。",
    "卯": "主木土相争，疾病在东方。",
    "辰": "主湿气生病，土地纠纷。",
    "巳": "主火邪入侵，口舌生疮。",
    "午": "主心火旺盛，急症。",
    "未": "主古墓棺椁之事，疾病在脾胃。",
    "申": "主刀伤或金石之灾。",
    "酉": "主肺疾，金石伤害。",
    "戌": "主旧病复发，坟墓之事。",
    "亥": "主水邪入体，肾疾。"
  },
  "天冲": {
    "子": "主北方有动，夜间提防。",
    "丑": "主动而有阻，不宜妄动。",
    "寅": "主出行大利，进发有功。",
    "卯": "主行动遂意，宜出击。",
    "辰": "主有贵人扶持，出行遇雨。",
    "巳": "主文书有动，信息传来。",
    "午": "主南方有大事发生。",
    "未": "主田宅变动，主人不安。",
    "申": "主行军交战，宜速不宜缓。",
    "酉": "主攻伐有功，但防口舌。",
    "戌": "主兵戈之事，宜守不宜攻。",
    "亥": "主暗中行动有利。"
  },
  "天辅": {
    "子": "主智慧聪明之事，文书有利。",
    "丑": "主文书迟滞，须等待时机。",
    "寅": "主出行有利，学业有成。",
    "卯": "主文章显达，考试顺利。",
    "辰": "主得贵人指点。",
    "巳": "主文书喜信，利于求学。",
    "午": "主文运亨通，大利科甲。",
    "未": "主文书有阻，须防小人。",
    "申": "主交通信息，出行顺利。",
    "酉": "主口才出众，宜演说。",
    "戌": "主文书入库，暂时不利。",
    "亥": "主夜间读书有成。"
  },
  "天禽": {
    "子": "主中央有变，须防水患。",
    "丑": "主田土中央之事。",
    "寅": "主出行半途有变。",
    "卯": "主东方有事牵连中宫。",
    "辰": "主土地城池之事。",
    "巳": "主中枢转变，事有转机。",
    "午": "主中心有火灾或血光。",
    "未": "主坟墓祖业之事。",
    "申": "主出行有转折。",
    "酉": "主中枢有金石之变。",
    "戌": "主中宫伏吟，守旧安然。",
    "亥": "主中枢暗流涌动。"
  },
  "天心": {
    "子": "主夜间有贵人降临。",
    "丑": "主药铺医馆有吉。",
    "寅": "主领导发号施令，宜出行。",
    "卯": "主交涉谈判有成。",
    "辰": "主有改革变化之事。",
    "巳": "主文武双全之事。",
    "午": "主光明正大行事。",
    "未": "主事有延迟，须耐心等候。",
    "申": "主军事行动，肃杀之气。",
    "酉": "主金石器物有变。",
    "戌": "主改革之事受阻。",
    "亥": "主夜间行事有利。"
  },
  "天柱": {
    "子": "主口舌是非，阴人搬弄。",
    "丑": "主毁坏败坏之事。",
    "寅": "主争讼出行，不利。",
    "卯": "主毁折损坏，小人当道。",
    "辰": "主口舌纷争不断。",
    "巳": "主是非口舌，防火灾。",
    "午": "主南方有争端。",
    "未": "主田宅毁坏，口角争端。",
    "申": "主刀兵争斗。",
    "酉": "主金属器物损坏，口角。",
    "戌": "主监牢之事，防犬伤。",
    "亥": "主暗中有人算计。"
  },
  "天任": {
    "子": "主仁慈之人暗助。",
    "丑": "主田产土地有增。",
    "寅": "主出行遇贵人。",
    "卯": "主仁政施惠，好事将近。",
    "辰": "主土地城建有利。",
    "巳": "主善举有成，乐善好施。",
    "午": "主光明善事，积德行善。",
    "未": "主田宅增益，稳固根基。",
    "申": "主出行有助，路遇善人。",
    "酉": "主和善解决纷争。",
    "戌": "主稳固守成，墓地吉利。",
    "亥": "主暗中生财，水利有功。"
  },
  "天英": {
    "子": "主文书失落，水火相克。",
    "丑": "主火烛之灾。",
    "寅": "主雷火并行，急事急办。",
    "卯": "主火灾、电器损坏。",
    "辰": "主雷电交加。",
    "巳": "主火灾、血光。",
    "午": "主大火灾，凶险至极。",
    "未": "主火烧田宅。",
    "申": "主军火之事。",
    "酉": "主冶炼之事。",
    "戌": "主火入坟墓，家宅不安。",
    "亥": "主水火不济。"
  }
}
