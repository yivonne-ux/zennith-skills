# GrabFood Listing Optimizer — Environment Variables

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# OpenAI / LLM (for menu copywriting)
OPENAI_API_KEY=sk-...

# FoodShot AI (optional — can use manual upload)
FOODSHOT_API_KEY=

# Gemini (for image editing via NanoBanana)
GEMINI_API_KEY=

# Proxy (optional — for anti-detection)
PROXY_URL=

# Data paths
DATA_DIR=./data
SESSIONS_DIR=./sessions
