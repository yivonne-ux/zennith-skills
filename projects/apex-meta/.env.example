# =============================================================================
# APEX META — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- App ---
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://apex:apex_secret@localhost:5432/apex_meta

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (Embeddings only) ---
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMS=3072

# --- Pinecone (Vector DB) ---
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=apex-meta
PINECONE_INDEX_DIMS=3072

# --- Meta Graph API ---
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_SYSTEM_USER_TOKEN=
META_API_DRY_RUN=true

# --- Serper (Web Search) ---
SERPER_API_KEY=

# --- YouTube Data API ---
YOUTUBE_API_KEY=

# --- AWS S3 (Creative Assets) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET_CREATIVES=apex-meta-creatives

# --- Deployment Safety Gates ---
DEPLOYMENT_AUTO_EXECUTE=false
DEPLOYMENT_MAX_DAILY_SPEND_INCREASE_PCT=20
DEPLOYMENT_KILL_REQUIRES_APPROVAL=true
DEPLOYMENT_NEW_CAMPAIGN_REQUIRES_APPROVAL=true
DEPLOYMENT_SCALE_REQUIRES_APPROVAL=false

# --- Default Thresholds ---
DEFAULT_ROAS_TARGET=3.0
DEFAULT_CPA_CEILING_MULTIPLIER=1.5
DEFAULT_CTR_FLOOR=0.01
DEFAULT_FREQUENCY_CEILING=3.5
DEFAULT_HOOK_RATE_FLOOR=0.20
AB_TEST_CONFIDENCE_THRESHOLD=0.80

# --- RAG ---
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.75
RAG_MAX_CONTEXT_CHUNKS=5
