#!/usr/bin/env bash
# mission-check.sh — Periodic mission progress checker for GAIA CORP-OS
# Reads MISSIONS.md, scans rooms for activity, detects stuck/failed missions,
# spawns agents with A/B/C retry strategies until resolved.
#
# Runs every 10 min via system crontab.
# Usage: bash mission-check.sh [--verbose]

set -uo pipefail

# Ensure PATH includes openclaw binary location (cron has minimal PATH)
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:$PATH"

OPENCLAW_DIR="$HOME/.openclaw"
WORKSPACE="$OPENCLAW_DIR/workspace"
MISSIONS_FILE="$WORKSPACE/MISSIONS.md"
ROOMS_DIR="$WORKSPACE/rooms"
SKILLS_DIR="$OPENCLAW_DIR/skills"
LOG_FILE="$OPENCLAW_DIR/logs/mission-check.log"
STATE_FILE="$OPENCLAW_DIR/logs/mission-state.json"
DISPATCH="$SKILLS_DIR/mission-control/scripts/dispatch.sh"
DELEGATE="$SKILLS_DIR/orchestrate/scripts/delegate.sh"
CLAUDE_RUNNER="$SKILLS_DIR/claude-code/scripts/claude-code-runner.sh"
VERBOSE="${1:-}"

TS_EPOCH=$(date +%s)
TS_ISO=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
TS_LOCAL=$(date +"%Y-%m-%d %H:%M:%S %Z")

mkdir -p "$(dirname "$LOG_FILE")" "$ROOMS_DIR"

log() {
  echo "[$TS_LOCAL] $1" >> "$LOG_FILE"
  [ "$VERBOSE" = "--verbose" ] && echo "$1"
}

post_to_room() {
  local room="$1" agent="$2" msg="$3" type="${4:-mission-check}"
  local safe_msg=$(echo "$msg" | tr '\n' ' ' | sed 's/"/\\"/g' | head -c 1500)
  local entry="{\"ts\":${TS_EPOCH}000,\"agent\":\"$agent\",\"room\":\"$room\",\"type\":\"$type\",\"msg\":\"$safe_msg\"}"
  echo "$entry" >> "$ROOMS_DIR/${room}.jsonl" 2>/dev/null
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STATE MANAGEMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

init_state() {
  if [ ! -f "$STATE_FILE" ]; then
    echo '{"missions":{},"circuit_breakers":{},"last_check":0}' > "$STATE_FILE"
  fi
}

get_mission_state() {
  local mission_id="$1"
  python3 - "$STATE_FILE" "$mission_id" << 'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        state = json.load(f)
    m = state.get("missions", {}).get(sys.argv[2], {})
    print(json.dumps(m))
except:
    print("{}")
PYEOF
}

update_mission_state() {
  local mission_id="$1" strategy="$2" result="$3"
  python3 - "$STATE_FILE" "$mission_id" "$strategy" "$result" "$TS_EPOCH" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
mission_id = sys.argv[2]
strategy = sys.argv[3]
result = sys.argv[4]
now = int(sys.argv[5])

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

missions = state.setdefault("missions", {})
m = missions.setdefault(mission_id, {"attempts": [], "last_strategy": None, "resolved": False})

m["attempts"].append({
    "ts": now,
    "strategy": strategy,
    "result": result
})
m["last_strategy"] = strategy

# Keep only last 20 attempts per mission
m["attempts"] = m["attempts"][-20:]

# If result is success, mark resolved
if result == "success":
    m["resolved"] = True

state["last_check"] = now

with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
}

check_circuit_breaker() {
  local agent_id="$1"
  python3 - "$STATE_FILE" "$agent_id" "$TS_EPOCH" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
agent_id = sys.argv[2]
now = int(sys.argv[3])

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

cb = state.get("circuit_breakers", {}).get(agent_id, {})
if cb.get("circuit") == "open":
    cooldown = cb.get("cooldown_until", 0)
    if now < cooldown:
        print("open")
    else:
        print("half-open")
else:
    print("closed")
PYEOF
}

trip_circuit_breaker() {
  local agent_id="$1" cooldown_seconds="${2:-600}"
  python3 - "$STATE_FILE" "$agent_id" "$TS_EPOCH" "$cooldown_seconds" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
agent_id = sys.argv[2]
now = int(sys.argv[3])
cooldown = int(sys.argv[4])

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

cbs = state.setdefault("circuit_breakers", {})
cb = cbs.setdefault(agent_id, {"consecutive_failures": 0, "circuit": "closed"})
cb["consecutive_failures"] = cb.get("consecutive_failures", 0) + 1
if cb["consecutive_failures"] >= 3:
    cb["circuit"] = "open"
    cb["cooldown_until"] = now + cooldown

with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
}

reset_circuit_breaker() {
  local agent_id="$1"
  python3 - "$STATE_FILE" "$agent_id" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
agent_id = sys.argv[2]

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

cbs = state.setdefault("circuit_breakers", {})
cbs[agent_id] = {"consecutive_failures": 0, "circuit": "closed"}

with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AGENT INVOCATION HELPERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

invoke_agent() {
  local agent_id="$1" message="$2" timeout_s="${3:-300}"

  # Check circuit breaker
  local cb_status
  cb_status=$(check_circuit_breaker "$agent_id")
  if [ "$cb_status" = "open" ]; then
    log "CIRCUIT OPEN for $agent_id — skipping invocation"
    echo "CIRCUIT_OPEN"
    return 1
  fi

  local result=""
  local exit_code=0

  if command -v openclaw &>/dev/null; then
    # macOS has no `timeout` — use background + wait + kill pattern
    openclaw agent --agent "$agent_id" --message "$message" --json > /tmp/mc-resp-$$.json 2>&1 &
    local bgpid=$!
    local waited=0
    while kill -0 "$bgpid" 2>/dev/null && [ "$waited" -lt "$timeout_s" ]; do
      sleep 1
      waited=$((waited + 1))
    done
    if kill -0 "$bgpid" 2>/dev/null; then
      kill "$bgpid" 2>/dev/null || true
      result='{"error":"timeout after '"$timeout_s"'s"}'
      exit_code=124
    else
      wait "$bgpid" 2>/dev/null || exit_code=$?
      result=$(cat /tmp/mc-resp-$$.json 2>/dev/null || echo '{"error":"no output"}')
    fi
    rm -f /tmp/mc-resp-$$.json
  else
    log "ERROR: openclaw not in PATH"
    echo "NO_OPENCLAW"
    return 127
  fi

  if [ "$exit_code" -ne 0 ]; then
    trip_circuit_breaker "$agent_id"
    log "Agent $agent_id failed (exit $exit_code)"
    echo "FAIL:$exit_code"
    return "$exit_code"
  fi

  # Extract text from response
  local text
  text=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['result']['payloads'][0]['text'][:2000])" 2>/dev/null || echo "$result" | head -c 2000)

  # Success — reset circuit breaker
  reset_circuit_breaker "$agent_id"

  echo "$text"
  return 0
}

invoke_claude_code() {
  local prompt="$1" cwd="${2:-$OPENCLAW_DIR}" budget="${3:-2.00}"

  if [ ! -x "$CLAUDE_RUNNER" ]; then
    log "WARN: claude-code-runner.sh not found"
    echo "NO_RUNNER"
    return 1
  fi

  local result
  result=$(bash "$CLAUDE_RUNNER" build "$prompt" "$cwd" "$budget" 2>&1 | tail -100)
  echo "$result"
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# A/B/C RETRY STRATEGIES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Generic A/B/C retry for a mission error
# Returns: "success" or "escalated"
try_abc() {
  local mission_id="$1"
  local error_type="$2"
  local error_detail="$3"
  local primary_agent="$4"
  local room="$5"

  # Check what strategies have been tried already
  local mstate
  mstate=$(get_mission_state "$mission_id")
  local last_strategy
  last_strategy=$(echo "$mstate" | python3 -c "import sys,json; print(json.load(sys.stdin).get('last_strategy','none'))" 2>/dev/null || echo "none")
  local is_resolved
  is_resolved=$(echo "$mstate" | python3 -c "import sys,json; print(json.load(sys.stdin).get('resolved',False))" 2>/dev/null || echo "False")

  if [ "$is_resolved" = "True" ]; then
    log "Mission $mission_id already resolved — skipping"
    return 0
  fi

  # Determine which strategy to try next
  local next_strategy
  case "$last_strategy" in
    none)   next_strategy="A" ;;
    A)      next_strategy="B" ;;
    B)      next_strategy="C" ;;
    C|*)    next_strategy="ESCALATE" ;;
  esac

  log "Mission $mission_id: error_type=$error_type, last=$last_strategy, next=$next_strategy"

  case "$next_strategy" in
    A)
      # Strategy A: The obvious fix (retry with primary agent, more context)
      log "[$mission_id] Strategy A: Retry $primary_agent with enriched context"
      local a_prompt="MISSION: $mission_id
ERROR: $error_type — $error_detail

You previously attempted this and it failed. Try again with a fresh approach.
- Read your SOUL.md for identity
- Check rooms for recent context
- Complete the task and post results

TASK: Fix the issue described above. If the task was incomplete, complete it now."

      local a_result
      a_result=$(invoke_agent "$primary_agent" "$a_prompt" 300) || true

      if echo "$a_result" | grep -qiE "CIRCUIT_OPEN|FAIL:|NO_OPENCLAW"; then
        update_mission_state "$mission_id" "A" "fail"
        post_to_room "$room" "mission-control" "[$mission_id] Strategy A failed ($primary_agent): $a_result" "retry"
      else
        update_mission_state "$mission_id" "A" "success"
        post_to_room "$room" "$primary_agent" "[$mission_id] Strategy A resolved: ${a_result:0:500}" "mission-result"
        log "[$mission_id] Strategy A succeeded"
        return 0
      fi
      ;;

    B)
      # Strategy B: Alternative approach (different agent or different method)
      log "[$mission_id] Strategy B: Alternative agent or method"

      # Pick an alternative agent based on error type
      local alt_agent
      case "$error_type" in
        research|scraping)   alt_agent="athena" ;;   # Athena can do analytical research
        content|creative)    alt_agent="iris" ;;      # Iris can help with content
        pricing|commerce)    alt_agent="athena" ;;    # Athena for financial analysis
        analytics|reporting) alt_agent="artemis" ;;   # Artemis can gather data
        code|tools)          alt_agent="taoz" ;;
        *)                   alt_agent="artemis" ;;   # Default: send scout
      esac

      # Don't use same agent as Strategy A
      if [ "$alt_agent" = "$primary_agent" ]; then
        alt_agent="artemis"
        [ "$alt_agent" = "$primary_agent" ] && alt_agent="athena"
      fi

      local b_prompt="MISSION: $mission_id
CONTEXT: The primary agent ($primary_agent) failed at this task.
ERROR: $error_type — $error_detail

You are being called as backup. Try a different approach than what was attempted.
- Use alternative data sources or methods
- Break the problem down differently
- Post results to $room room"

      # Special case: code tasks go to Claude Code
      if [ "$alt_agent" = "taoz" ]; then
        local b_result
        b_result=$(invoke_claude_code "Mission $mission_id failed. Error: $error_type — $error_detail. Diagnose and fix." "$OPENCLAW_DIR" "2.00") || true
        if [ -n "$b_result" ] && ! echo "$b_result" | grep -q "NO_RUNNER"; then
          update_mission_state "$mission_id" "B" "success"
          post_to_room "$room" "taoz" "[$mission_id] Strategy B (Claude Code) resolved: ${b_result:0:500}" "mission-result"
          log "[$mission_id] Strategy B (Claude Code) succeeded"
          return 0
        fi
      else
        local b_result
        b_result=$(invoke_agent "$alt_agent" "$b_prompt" 300) || true

        if echo "$b_result" | grep -qiE "CIRCUIT_OPEN|FAIL:|NO_OPENCLAW"; then
          update_mission_state "$mission_id" "B" "fail"
          post_to_room "$room" "mission-control" "[$mission_id] Strategy B failed ($alt_agent): $b_result" "retry"
        else
          update_mission_state "$mission_id" "B" "success"
          post_to_room "$room" "$alt_agent" "[$mission_id] Strategy B resolved: ${b_result:0:500}" "mission-result"
          log "[$mission_id] Strategy B succeeded"
          return 0
        fi
      fi

      update_mission_state "$mission_id" "B" "fail"
      ;;

    C)
      # Strategy C: Creative solution (break task down, search for solution, invoke Claude Code)
      log "[$mission_id] Strategy C: Creative solution via Claude Code Opus 4.6"

      # Gather context from rooms
      local room_context=""
      if [ -f "$ROOMS_DIR/${room}.jsonl" ]; then
        room_context=$(tail -20 "$ROOMS_DIR/${room}.jsonl" 2>/dev/null | head -c 3000)
      fi
      local feedback_context=""
      if [ -f "$ROOMS_DIR/feedback.jsonl" ]; then
        feedback_context=$(tail -10 "$ROOMS_DIR/feedback.jsonl" 2>/dev/null | head -c 1500)
      fi

      local c_prompt="GAIA CORP-OS Mission Control — Strategy C (creative fix)

Mission: $mission_id
Error type: $error_type
Error detail: $error_detail
Primary agent ($primary_agent) failed (Strategy A).
Alternative agent failed (Strategy B).

Recent room activity ($room):
$room_context

Recent feedback:
$feedback_context

INSTRUCTIONS:
1. Analyze WHY strategies A and B failed
2. Try a completely different approach:
   - Break the task into smaller subtasks
   - Search for alternative solutions
   - Fix any underlying infrastructure issues
   - Update config files if needed
3. If you fix it, describe exactly what you did
4. If you cannot fix it, explain what Jenn needs to do manually"

      local c_result
      c_result=$(invoke_claude_code "$c_prompt" "$WORKSPACE" "2.00") || true

      if [ -n "$c_result" ] && ! echo "$c_result" | grep -q "NO_RUNNER"; then
        update_mission_state "$mission_id" "C" "success"
        post_to_room "$room" "taoz" "[$mission_id] Strategy C (Claude Code creative fix): ${c_result:0:500}" "mission-result"
        post_to_room "feedback" "mission-control" "[$mission_id] Strategy C applied. Claude Code output: ${c_result:0:300}" "learning"
        log "[$mission_id] Strategy C completed"
        return 0
      fi

      update_mission_state "$mission_id" "C" "fail"
      ;;

    ESCALATE)
      # All strategies exhausted — escalate to Jenn
      log "[$mission_id] ALL STRATEGIES EXHAUSTED — escalating to Jenn"
      post_to_room "exec" "mission-control" "ESCALATION: Mission $mission_id has failed all A/B/C strategies. Error: $error_type — $error_detail. Needs Jenn's manual intervention." "escalation"
      post_to_room "feedback" "mission-control" "[$mission_id] Escalated to Jenn after A/B/C exhaustion" "escalation"
      update_mission_state "$mission_id" "ESCALATE" "escalated"
      return 1
      ;;
  esac

  return 1
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MISSION SCANNING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

scan_missions() {
  if [ ! -f "$MISSIONS_FILE" ]; then
    log "WARN: MISSIONS.md not found"
    return
  fi

  # Parse active missions from MISSIONS.md
  python3 - "$MISSIONS_FILE" "$ROOMS_DIR" "$TS_EPOCH" << 'PYEOF'
import re, json, sys, os

missions_file = sys.argv[1]
rooms_dir = sys.argv[2]
now = int(sys.argv[3])

with open(missions_file) as f:
    content = f.read()

# Extract missions
missions = []
pattern = r'### (M\d+): (.+)\n((?:(?:- \*\*|  ).+\n?)+)'
for match in re.finditer(pattern, content):
    mid = match.group(1)
    title = match.group(2).strip()
    body = match.group(3)

    # Extract fields
    status = re.search(r'\*\*Status:\*\*\s*(.+)', body)
    owner = re.search(r'\*\*Owner:\*\*\s*(.+)', body)
    priority = re.search(r'\*\*Priority:\*\*\s*(.+)', body)
    blockers = re.search(r'\*\*Blockers:\*\*\s*(.+)', body)
    room = re.search(r'\*\*Room:\*\*\s*(.+)', body)

    missions.append({
        "id": mid,
        "title": title,
        "status": status.group(1).strip() if status else "UNKNOWN",
        "owner": owner.group(1).strip() if owner else "unassigned",
        "priority": priority.group(1).strip() if priority else "P3",
        "blockers": blockers.group(1).strip() if blockers else "None",
        "room": room.group(1).strip() if room else "townhall"
    })

# Check room activity for each mission
for m in missions:
    room_file = os.path.join(rooms_dir, f"{m['room']}.jsonl")
    m["recent_activity"] = 0
    m["last_activity_ts"] = 0

    if os.path.exists(room_file):
        try:
            with open(room_file) as rf:
                lines = rf.readlines()
            # Count entries in last 2 hours
            cutoff = (now - 7200) * 1000
            for line in lines[-100:]:
                try:
                    entry = json.loads(line.strip())
                    ts = entry.get("ts", 0)
                    if ts > cutoff:
                        m["recent_activity"] += 1
                    if ts > m["last_activity_ts"]:
                        m["last_activity_ts"] = ts
                except:
                    pass
        except:
            pass

    # Calculate staleness (hours since last activity)
    if m["last_activity_ts"] > 0:
        m["stale_hours"] = (now * 1000 - m["last_activity_ts"]) / (3600 * 1000)
    else:
        m["stale_hours"] = 999

print(json.dumps(missions))
PYEOF
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ERROR DETECTION IN ROOMS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

scan_room_errors() {
  python3 - "$ROOMS_DIR" "$TS_EPOCH" << 'PYEOF'
import json, sys, os, glob

rooms_dir = sys.argv[1]
now = int(sys.argv[2])
cutoff = (now - 1800) * 1000  # Last 30 minutes

errors = []
for room_file in glob.glob(os.path.join(rooms_dir, "*.jsonl")):
    room_name = os.path.basename(room_file).replace(".jsonl", "")
    try:
        with open(room_file) as f:
            for line in f.readlines()[-50:]:
                try:
                    entry = json.loads(line.strip())
                    ts = entry.get("ts", 0)
                    if ts < cutoff:
                        continue
                    msg = entry.get("msg", "").lower()
                    etype = entry.get("type", "")

                    # Detect errors
                    is_error = False
                    error_type = "unknown"

                    if etype in ("delegation-failure", "incident", "escalation"):
                        is_error = True
                        error_type = etype
                    elif "fail" in msg or "error" in msg or "timeout" in msg:
                        is_error = True
                        if "timeout" in msg:
                            error_type = "timeout"
                        elif "cron" in msg:
                            error_type = "cron"
                        elif "model" in msg or "api" in msg:
                            error_type = "model"
                        else:
                            error_type = "runtime"

                    if is_error:
                        errors.append({
                            "room": room_name,
                            "agent": entry.get("agent", "unknown"),
                            "type": error_type,
                            "msg": entry.get("msg", "")[:300],
                            "ts": ts
                        })
                except:
                    pass
    except:
        pass

print(json.dumps(errors))
PYEOF
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ERROR DETECTION FROM MISSION STATE (unresolved errors)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

scan_mission_state_errors() {
  local STATE_FILE="$OPENCLAW_DIR/logs/mission-state.json"
  local TIME_THRESHOLD_HOURS=4  # Errors older than 4 hours are stale

  if [ ! -f "$STATE_FILE" ]; then
    echo "[]"
    return
  fi

  python3 - "$STATE_FILE" "$TS_EPOCH" "$TIME_THRESHOLD_HOURS" << 'PYEOF'
import json, sys, os

state_file = sys.argv[1]
now = int(sys.argv[2])
hours_threshold = float(sys.argv[3])

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    print("[]")
    sys.exit(0)

cutoff_seconds = now - (hours_threshold * 3600)
cutoff_ms = cutoff_seconds * 1000

errors = []
for key, data in state.get("missions", {}).items():
    if not key.startswith("ERR-"):
        continue

    # Check if resolved
    if data.get("resolved", False):
        continue

    # Check if error is stale
    attempts = data.get("attempts", [])
    if len(attempts) == 0:
        continue

    ts = attempts[-1].get("ts", 0)
    if ts < cutoff_ms:
        continue

    # Extract error type from key
    error_type = key.replace("ERR-", "")

    # Get last attempt
    attempts = data.get("attempts", [])
    if len(attempts) == 0:
        continue

    last_attempt = attempts[-1]
    result = last_attempt.get("result", "unknown")

    errors.append({
        "mission_id": key,
        "error_type": error_type,
        "last_attempt": result,
        "msg": f"Unresolved {error_type} error (Mission: {key})",
        "room": "build"  # Default room for technical errors
    })

print(json.dumps(errors))
PYEOF
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MAIN LOOP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

log "=== mission-check cycle start ==="
init_state

TMPDIR_MC="/tmp/mission-check-$$"
mkdir -p "$TMPDIR_MC"
trap "rm -rf $TMPDIR_MC" EXIT

# 1. Scan missions for staleness
MISSIONS_JSON=$(scan_missions 2>/dev/null || echo "[]")
MISSION_COUNT=$(echo "$MISSIONS_JSON" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")
log "Scanned $MISSION_COUNT missions"

# Write active missions to temp file (avoids subshell pipeline)
echo "$MISSIONS_JSON" | python3 -c "
import sys, json
missions = json.load(sys.stdin)
for m in missions:
    status = m.get('status', '')
    if any(s in status.upper() for s in ['IN_PROGRESS', 'ACTIVE', 'BLOCKED']):
        print(json.dumps(m))
" 2>/dev/null > "$TMPDIR_MC/active_missions.jsonl"

# Process each mission (read from file, not pipe)
while IFS= read -r mission_json; do
  MID=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['id'])" 2>/dev/null)
  MTITLE=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['title'])" 2>/dev/null)
  MROOM=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['room'])" 2>/dev/null)
  MOWNER=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['owner'])" 2>/dev/null)
  MSTALE=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['stale_hours'])" 2>/dev/null)
  MPRIORITY=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['priority'])" 2>/dev/null)
  MBLOCKERS=$(echo "$mission_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['blockers'])" 2>/dev/null)

  log "  $MID: $MTITLE (stale: ${MSTALE}h, priority: $MPRIORITY, room: $MROOM)"

  # Determine staleness threshold based on priority
  STALE_THRESHOLD=24
  case "$MPRIORITY" in
    P0) STALE_THRESHOLD=1 ;;   # Critical: stale after 1 hour
    P1) STALE_THRESHOLD=4 ;;   # High: stale after 4 hours
    P2) STALE_THRESHOLD=12 ;;  # Medium: stale after 12 hours
    *)  STALE_THRESHOLD=24 ;;  # Low: stale after 24 hours
  esac

  # Check if mission is stale (no room activity within threshold)
  STALE_INT=$(echo "$MSTALE" | python3 -c "import sys; print(int(float(sys.stdin.read().strip())))" 2>/dev/null || echo "0")
  if [ "$STALE_INT" -gt "$STALE_THRESHOLD" ] 2>/dev/null; then
    log "  STALE: $MID has been inactive for ${STALE_INT}h (threshold: ${STALE_THRESHOLD}h)"

    # Determine primary agent from owner field
    PRIMARY_AGENT=$(echo "$MOWNER" | python3 -c "
import sys
owner = sys.stdin.read().strip().lower()
agent_map = {
    'artemis': 'artemis', 'apollo': 'apollo', 'hermes': 'hermes',
    'athena': 'athena', 'iris': 'iris', 'zenni': 'main',
    'taoz': 'taoz'
}
for name, aid in agent_map.items():
    if name in owner:
        print(aid)
        break
else:
    print('artemis')
" 2>/dev/null || echo "artemis")

    # Try A/B/C strategies
    try_abc "$MID" "stale" "Mission inactive for ${STALE_INT}h. Title: $MTITLE. Blockers: $MBLOCKERS" "$PRIMARY_AGENT" "$MROOM"
  fi
done < "$TMPDIR_MC/active_missions.jsonl"

# 2. Scan rooms for recent errors
ERRORS_JSON=$(scan_room_errors 2>/dev/null || echo "[]")
ERROR_COUNT=$(echo "$ERRORS_JSON" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

if [ "$ERROR_COUNT" -gt 0 ] 2>/dev/null; then
  log "Found $ERROR_COUNT recent errors in rooms"

  # Write deduplicated errors to temp file
  echo "$ERRORS_JSON" | python3 -c "
import sys, json
errors = json.load(sys.stdin)
seen = set()
for e in errors:
    key = e['type'] + ':' + e['agent']
    if key not in seen:
        seen.add(key)
        print(json.dumps(e))
" 2>/dev/null > "$TMPDIR_MC/errors.jsonl"

  while IFS= read -r error_json; do
    EROOM=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['room'])" 2>/dev/null)
    EAGENT=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['agent'])" 2>/dev/null)
    ETYPE=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['type'])" 2>/dev/null)
    EMSG=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['msg'])" 2>/dev/null)

    log "  Error: $ETYPE from $EAGENT in $EROOM"

    # Map error to a synthetic mission ID for tracking
    ERROR_MID="ERR-${ETYPE}-${EAGENT}"

    try_abc "$ERROR_MID" "$ETYPE" "$EMSG" "$EAGENT" "$EROOM"
  done < "$TMPDIR_MC/errors.jsonl"
fi

# 3. Scan mission state for unresolved errors (timeout, runtime, etc.)
MISSION_STATE_ERRORS=$(scan_mission_state_errors 2>/dev/null || echo "[]")
MISSION_STATE_ERROR_COUNT=$(echo "$MISSION_STATE_ERRORS" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

if [ "$MISSION_STATE_ERROR_COUNT" -gt 0 ] 2>/dev/null; then
  log "Found $MISSION_STATE_ERROR_COUNT unresolved errors in mission-state.json"

  # Write to temp file
  echo "$MISSION_STATE_ERRORS" 2>/dev/null > "$TMPDIR_MC/mission-state-errors.jsonl"

  while IFS= read -r error_json; do
    EMISSION_ID=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['mission_id'])" 2>/dev/null)
    ETYPE=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['error_type'])" 2>/dev/null) || ETYPE="unknown"
    EMSG=$(echo "$error_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['msg'])" 2>/dev/null) || EMSG="Unknown error"

    log "  Unresolved error: $EMISSION_ID ($ETYPE)"

    # Reset circuit breaker for this agent if stuck open (after cooldown)
    # Extract agent name from error ID (ERR-timeout-athena -> athena)
    EAGENT="${EMISSION_ID#*-}"
    EAGENT="${EAGENT#*-}"
    EAGENT="${EAGENT%%-*}"

    if [ "$ETYPE" = "timeout" ] || [ "$ETYPE" = "runtime" ]; then
      log "    Resetting circuit breaker for $EAGENT (timeout/runtime error)"

      # Wait for cooldown to expire before resetting
      if [ -f "$STATE_FILE" ]; then
        cooldown=$(python3 - "$STATE_FILE" "$EAGENT" << 'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        state = json.load(f)
    cb = state.get("circuit_breakers", {}).get(sys.argv[2], {})
    if cb.get("circuit") == "open":
        print(cb.get("cooldown_until", 0))
    else:
        print(0)
except:
    print(0)
PYEOF
)
        if [ "$cooldown" -lt $(date +%s) ]; then
          python3 - "$STATE_FILE" "$EAGENT" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
agent_id = sys.argv[2]

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

cbs = state.setdefault("circuit_breakers", {})
cbs[agent_id] = {"consecutive_failures": 0, "circuit": "closed"}

with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
          log "      Circuit breaker reset for $EAGENT"
        fi
      fi

      # Trigger retry strategy
      try_abc "$EMISSION_ID" "$ETYPE" "$EMSG" "$EAGENT" "build"
    fi
  done < "$TMPDIR_MC/mission-state-errors.jsonl"
fi

# 3. Log feedback summary
TOTAL_ACTIONS=0
if [ "$MISSION_COUNT" -gt 0 ] || [ "$ERROR_COUNT" -gt 0 ]; then
  SUMMARY="mission-check: scanned $MISSION_COUNT missions, found $ERROR_COUNT errors"
  post_to_room "feedback" "mission-control" "$SUMMARY" "mission-check"
  log "$SUMMARY"
fi

# 4. Reset stuck circuit breakers (manual intervention for stuck system)
RESET_CB_LIST=$(python3 - "$STATE_FILE" "$TS_EPOCH" << 'PYEOF'
import json, sys, datetime, time

state_file = sys.argv[1]
now = int(sys.argv[2])

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    print("[]")
    sys.exit(0)

cbs = state.get("circuit_breakers", {})
reset_agents = []

for agent_id, cb in cbs.items():
    if cb.get("circuit") == "open":
        cooldown = cb.get("cooldown_until", 0)
        if cooldown > 0 and cooldown > now:
            # Still in cooldown - skip
            continue

        # Allow manual reset for stuck circuits (P0/P1 tasks)
        if agent_id in ("mission-control", "taoz"):
            reset_agents.append(agent_id)

print(json.dumps(reset_agents))
PYEOF
)

RESET_CB_COUNT=$(echo "$RESET_CB_LIST" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

if [ "$RESET_CB_COUNT" -gt 0 ] 2>/dev/null; then
  log "Manual reset of stuck circuit breakers: $RESET_CB_LIST"

  while IFS= read -r agent_id; do
    python3 - "$STATE_FILE" "$agent_id" << 'PYEOF'
import json, sys

state_file = sys.argv[1]
agent_id = sys.argv[2]

try:
    with open(state_file) as f:
        state = json.load(f)
except:
    state = {"missions": {}, "circuit_breakers": {}, "last_check": 0}

cbs = state.setdefault("circuit_breakers", {})
cbs[agent_id] = {"consecutive_failures": 0, "circuit": "closed"}

with open(state_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    log "  Reset circuit breaker for $agent_id"
  done <<< "$RESET_CB_LIST"
fi

# 5. Trim log
if [ -f "$LOG_FILE" ]; then
  LINE_COUNT=$(wc -l < "$LOG_FILE" 2>/dev/null | tr -d ' ' || echo "0")
  LINE_COUNT=${LINE_COUNT:-0}
  if [ "$LINE_COUNT" -gt 5000 ] 2>/dev/null; then
    tail -2000 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
    log "Trimmed mission-check log"
  fi
fi

log "=== mission-check cycle complete ==="
